# AI Service (groq, gemini, or claude)
AI_SERVICE=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your_gemini_api_key_here

# SoSoValue API
SOSOVALUE_API_KEY=your_sosovalue_key_here
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1

# Optional SoSoValue endpoint overrides if their API paths change
# SOSOVALUE_NEWS_PATH=/news
# SOSOVALUE_ETF_LIST_PATH=/etf/list
# SOSOVALUE_ETF_SUMMARY_HISTORY_PATH=/etf/summary-history
# SOSOVALUE_SSI_LIST_PATH=/sosovalue-index/list
# SOSOVALUE_FUNDRAISING_PATH=/fundraising/list
# SOSOVALUE_COIN_MARKET_PATH=/currencies/market-data

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

# SoDEX Testnet
SODEX_TESTNET_PERPS=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT=https://testnet-gw.sodex.dev/api/v1/spot

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# User Wallet
USER_WALLET_ADDRESS=0x6b3a924379B9408D8110f10F084ca809863B378A

# Dashboard URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# App Config
CYCLE_INTERVAL_MS=1800000
RISK_ALERT_THRESHOLD=65
AUTO_EXECUTE=false
PORT=3001
