# Runtime
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000
SODEX_SESSION_SECRET=replace-with-at-least-32-random-characters
SODEX_SESSION_TTL_MS=86400000
# Dedicated AES-256-GCM root secret for user-scoped CEX read-only credentials.
ENABLE_CROSS_EXCHANGE_SHIELD=false
EXCHANGE_CREDENTIALS_KEY=replace-with-an-independent-32-character-secret
CRON_SECRET=replace-with-an-independent-32-character-secret
# Explicit operator-login identities. For live execution, do not use the SoDEX master account address.
OPERATOR_WALLET_ADDRESSES=0x0000000000000000000000000000000000000000

# Persistence (service role is mandatory in production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Market intelligence
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1
AI_SERVICE=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
XAI_API_KEY=
XAI_MODEL=grok-3
GEMINI_API_KEY=
GEMINI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SKILLMINT_AGENT_KEY=
SKILLMINT_NETWORK=mainnet
SKILLMINT_NARRATIVE_SKILL_ID=2
SKILLMINT_RISK_SKILL_ID=2
SKILLMINT_SUMMARY_SKILL_ID=2
SKILLMINT_X402_URL=

# SoDEX
SODEX_NETWORK=testnet
SODEX_TESTNET_PERPS=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_MAINNET_PERPS=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_MAINNET_SPOT=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_ACCOUNT_ADDRESS=
SODEX_ACCOUNT_ID=
SODEX_API_KEY_NAME=
SODEX_API_PRIVATE_KEY=
SODEX_MANAGED_PRIVATE_KEY=
SODEX_CHAIN_ID=138565
SODEX_TESTNET_RPC_URL=https://testnet-v2.valuechain.xyz
SODEX_MAINNET_RPC_URL=https://mainnet.valuechain.xyz
# Set these only after deploying and auditing contracts/src/ShieldAutomationExecutor.sol.
SHIELD_AUTOMATION_CONTRACT_ADDRESS=
SHIELD_AUTOMATION_TESTNET_CONTRACT_ADDRESS=
SHIELD_AUTOMATION_MAINNET_CONTRACT_ADDRESS=
KEY_PROVIDER=disabled
EXECUTION_MODE=dry_run
# Live execution requires the production-hardening migration, KEY_PROVIDER=managed,
# a non-default registered SODEX_API_KEY_NAME, and a signing key distinct from
# SODEX_ACCOUNT_ADDRESS. For an approved mainnet canary, change all three:
# SODEX_NETWORK=mainnet
# SODEX_CHAIN_ID=286623
# EXECUTION_MODE=mainnet_canary
ALLOWED_SYMBOLS=BTC-USD,ETH-USD,SOL-USD
MAX_LEVERAGE=25
MAX_NOTIONAL_USD=10000
ACTION_COOLDOWN_MS=60000

# Agents and validation
ENABLE_BACKGROUND_SCHEDULER=true
ENABLE_TELEGRAM_BOT=false
CYCLE_INTERVAL_MS=1800000
DAILY_SUMMARY_UTC_HOUR=8
RISK_ALERT_THRESHOLD=65
RISK_ALERT_COOLDOWN_MS=1800000
USER_WALLET_ADDRESS=
NARRATIVE_MODEL_VERSION=narrative-v2.0.0
SIGNAL_BENCHMARK_SYMBOL=BTC-USD
SIGNAL_OUTCOME_NETWORK=testnet
SIGNAL_OUTCOME_INTERVAL=1h
SIGNAL_OUTCOME_KLINE_LIMIT=250
SIGNAL_OUTCOME_MAX_CANDLE_DISTANCE_MS=5400000
SIGNAL_OUTCOME_EXPIRY_MS=864000000
SECTOR_PROXY_SYMBOLS=

# Optional SoSoValue endpoint overrides (leave empty to use built-in discovery)
SOSOVALUE_NEWS_PATH=
SOSOVALUE_ETF_LIST_PATH=
SOSOVALUE_ETF_SUMMARY_HISTORY_PATH=
SOSOVALUE_SSI_LIST_PATH=
SOSOVALUE_SSI_HISTORY_PATH=
SOSOVALUE_FUNDRAISING_PATH=
SOSOVALUE_COIN_MARKET_PATH=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
