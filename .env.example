# AI Service (groq, gemini, claude, or skillmint)
# - "skillmint" routes every memo through TEE-attested execution on 0G mainnet
#   and returns an on-chain receipt rootHash alongside the memo. See
#   backend/services/skillmint.ts for the full design rationale.
# - All four adapters expose the same generateNarrativeMemo / generateRiskMemo /
#   generateDailySummary API, so flipping AI_SERVICE is the only change needed.
AI_SERVICE=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your_gemini_api_key_here

# ── SkillMint (verifiable AI execution on 0G mainnet) ────────────────────────
# Only required when AI_SERVICE=skillmint. The adapter falls back to local
# plaintext memos if any of these are unset or invalid — the agent cycle never
# crashes.
#
# SKILLMINT_AGENT_KEY: private key of the server wallet that pays for each
#   memo call. Needs USDC.E balance on 0G mainnet (bridge via XSwap).
#   Roughly $0.01 per memo. At 3 memos × 48 cycles/day = ~$1.50/day.
SKILLMINT_AGENT_KEY=your_0x_server_wallet_private_key_here
# SKILLMINT_NETWORK: "mainnet" (default) or "testnet"
SKILLMINT_NETWORK=mainnet
# SKILLMINT_*_SKILL_ID: which SkillMint skills (ERC-721 NFTs on 0G) handle
# each memo type. Default 2 = "0G Expert" (a general-purpose analyst skill
# already live on mainnet). For production, publish a Sentinel-specific skill
# with the prompt template encrypted on 0G Storage and put its skillId here.
SKILLMINT_NARRATIVE_SKILL_ID=2
SKILLMINT_RISK_SKILL_ID=2
SKILLMINT_SUMMARY_SKILL_ID=2
# SKILLMINT_X402_URL: optional override for the x402 facilitator endpoint.
# Leave unset to use the SDK's built-in mainnet alias.
# SKILLMINT_X402_URL=https://skillmint-0g.vercel.app/api/x402

# SoSoValue API
SOSOVALUE_API_KEY=your_sosovalue_key_here
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1

# Optional SoSoValue endpoint overrides if their API paths change
# SOSOVALUE_NEWS_PATH=/news
# SOSOVALUE_ETF_LIST_PATH=/etf/list
# SOSOVALUE_ETF_SUMMARY_HISTORY_PATH=/etf/summary-history
# SOSOVALUE_SSI_LIST_PATH=/sosovalue-index/list
# SOSOVALUE_FUNDRAISING_PATH=/fundraising/list
# SOSOVALUE_COIN_MARKET_PATH=/currencies/market-data

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

# SoDEX Testnet
SODEX_TESTNET_PERPS=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT=https://testnet-gw.sodex.dev/api/v1/spot

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# User Wallet
USER_WALLET_ADDRESS=0x6b3a924379B9408D8110f10F084ca809863B378A

# Dashboard URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# App Config
CYCLE_INTERVAL_MS=1800000
RISK_ALERT_THRESHOLD=65
AUTO_EXECUTE=false
PORT=3001
