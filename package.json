{
  "name": "sentinel-finance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "tsx backend/server.ts",
    "dev": "tsx watch backend/server.ts",
    "test": "tsx backend/tests/run.ts",
    "typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "lint": "npm --prefix frontend run lint",
    "docs:check": "node scripts/check-docs.mjs",
    "contracts:compile": "node scripts/compile-contracts.mjs",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "check": "npm run docs:check && npm run contracts:compile && npm run typecheck && npm run lint && npm test && npm run frontend:build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@google/generative-ai": "^0.24.1",
    "@skillmint/sdk": "^0.4.1",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "ethers": "^6.16.0",
    "express": "^4.18.0",
    "groq-sdk": "^1.1.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "nodemon": "^3.0.0",
    "solc": "^0.8.36",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "tsx": {
      "esbuild": "0.28.1"
    }
  }
}
