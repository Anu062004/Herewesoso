{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts", "./types/**/*.d.ts"],
  "exclude": ["../node_modules"]
}
